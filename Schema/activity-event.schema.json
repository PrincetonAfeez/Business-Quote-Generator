{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-project": "Business Quote Generator",
  "x-note": "Academic schema summary derived from Django models; migrations remain the database source of truth.",
  "title": "ActivityEvent",
  "type": "object",
  "required": [
    "id",
    "quote_id",
    "event_type",
    "timestamp",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "quote_id": {
      "type": "integer",
      "minimum": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "created",
        "sent",
        "viewed",
        "accepted",
        "declined",
        "duplicated",
        "edited",
        "expired"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
