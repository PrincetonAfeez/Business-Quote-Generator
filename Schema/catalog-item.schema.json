{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-project": "Business Quote Generator",
  "x-note": "Academic schema summary derived from Django models; migrations remain the database source of truth.",
  "title": "CatalogItem",
  "type": "object",
  "required": [
    "id",
    "owner_id",
    "name",
    "default_unit_price",
    "unit",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "owner_id": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "default_unit_price": {
      "type": "string",
      "pattern": "^\\\\d+(\\\\.\\\\d{2})$",
      "description": "Decimal >= 0.00.",
      "minimum_note": "0.00"
    },
    "unit": {
      "type": "string",
      "enum": [
        "hour",
        "day",
        "each",
        "sqft",
        "word",
        "page"
      ],
      "default": "each"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
